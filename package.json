{
  "name": "piggy",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared",
    "packages/contracts"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev --workspace=@piggy/client",
    "dev:server": "npm run dev --workspace=@piggy/server",
    "build": "npm run build --workspace=@piggy/server && npm run build --workspace=@piggy/client",
    "start": "node server/dist/index.js",
    "lint": "npm run lint --workspace=@piggy/client && npm run lint --workspace=@piggy/server",
    "test": "npm run test --workspaces",
    "db:generate": "npm run db:generate --workspace=@piggy/server",
    "db:migrate": "npm run db:migrate --workspace=@piggy/server",
    "db:push": "npm run db:push --workspace=@piggy/server",
    "compile:contracts": "npm run compile --workspace=@piggy/contracts",
    "test:contracts": "npm run test --workspace=@piggy/contracts",
    "deploy:contracts:amoy": "npm run deploy:amoy --workspace=@piggy/contracts",
    "deploy:contracts:mainnet": "npm run deploy:mainnet --workspace=@piggy/contracts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/mocha": "^10.0.10",
    "concurrently": "^9.1.2",
    "hardhat-gas-reporter": "^1.0.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "typechain": "^8.3.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ]
  }
}
