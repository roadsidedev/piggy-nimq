# Paymaster endpoint for gas sponsorship (ERC-4337)
VITE_PAYMASTER_URL=
VITE_PAYMASTER_API_KEY=

# Polygon RPC (optional — defaults to public endpoints)
VITE_POLYGON_RPC_URL=
VITE_POLYGON_AMOY_RPC_URL=

# Testnet mode (true = use Amoy testnet, false = use Polygon mainnet)
VITE_USE_TESTNET=true

# Cloudinary (required for profile picture uploads)
# Sign up at https://cloudinary.com — free tier gives 10GB storage
# Create an unsigned upload preset named "piggy_pfp" in your Cloudinary dashboard
CLOUDINARY_CLOUD_NAME=
